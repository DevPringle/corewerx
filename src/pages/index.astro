---
import MainLayout from "../layouts/MainLayout.astro";
import { getCollection } from "astro:content";

const latestPosts = (await getCollection("blog")).slice(0, 2);
---

<MainLayout title="Home">

<h1>
FiveM resources built with purpose.
</h1>

<p>
CoreWerx creates scripts, assets, and tools for FiveM communities while documenting the ideas and processes behind them.
</p>


<h2>
Latest from the blog
</h2>

<p>
  Read the latest posts and explore the full archive.
</p>

<ul>
  {latestPosts.map((post) => (
    <li>
      <a href={`/blog/${post.id}`}>
        {post.data.title}
      </a>
    </li>
  ))}
</ul>

<p>
  <a href="/blog">Visit the blog →</a>
</p>


</MainLayout>