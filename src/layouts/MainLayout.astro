---
import "../styles/global.css";

const { title, description, socialImage } = Astro.props;
const siteOrigin = Astro.site ?? "https://corewerx.pages.dev";
const shareImage = socialImage ?? "/images/site-social.png";
const absoluteShareImage = shareImage.startsWith("http") ? shareImage : `${siteOrigin}${shareImage}`;
const pageTitle = title ? `${title} · CoreWerx` : "CoreWerx";
const pageDescription = description ?? "CoreWerx creates scripts, assets, and tools for FiveM communities while documenting the ideas and processes behind them.";
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content={pageDescription} />
  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={pageDescription} />
  <meta property="og:image" content={absoluteShareImage} />
  <meta property="og:type" content="article" />
  <meta property="og:url" content={siteOrigin + Astro.url.pathname} />
  <meta property="twitter:card" content="summary_large_image" />
  <meta property="twitter:title" content={pageTitle} />
  <meta property="twitter:description" content={pageDescription} />
  <meta property="twitter:image" content={absoluteShareImage} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700&display=swap" rel="stylesheet" />
  <link href="https://fonts.cdnfonts.com/css/monument-extended" rel="stylesheet" />
  <title>{pageTitle}</title>
</head>

<body>

<main class="container">
  <header>
    <a href="/" class="logo">
      <img src="/images/corewerx-icon.png" alt="CoreWerx icon" class="logo-mark" />
      <span>CoreWerx</span>
    </a>
    <nav>
      <a href="/blog">Blog</a>
      <a href="/resources">Resources</a>
    </nav>
  </header>

  <slot />

</main>

</body>
</html>